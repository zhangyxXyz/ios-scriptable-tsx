        "dev:all": "cross-env NODE_ENV=development compileType=all ts-node ./src/build/compile.ts",
        "build": "cross-env NODE_ENV=production compileType=one ts-node ./src/build/compile.ts",
        "build:all": "cross-env NODE_ENV=production compileType=all ts-node ./src/build/compile.ts",
        "format": "prettier --write \"src/**/*.{ts,tsx,js}\" \"*.js\" \"*.json\""
    },
    "license": "MIT",
    "devDependencies": {
        "@eslint/js": "^9.15.0",
        "@types/eslint": "^9.6.0",
        "@types/express": "^4.17.21",
        "@types/fs-extra": "^11.0.4",
        "@types/lodash": "^4.17.0",
        "@types/node": "^20.10.0",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@types/scriptable-ios": "^1.6.1",
        "cross-env": "^7.0.3",
        "esbuild": "^0.27.0",
        "eslint": "^9.15.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.2.0",
        "globals": "^15.12.0",
        "javascript-obfuscator": "^4.2.0",
        "nodemon": "^3.1.11",
        "prettier": "^3.2.0",
        "ts-loader": "^9.5.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.0",
        "typescript-eslint": "^8.16.0"
    },
    "dependencies": {
        "@bradleyhodges/sfsymbols": "^7.0.4",
        "body-parser": "^1.20.2",
        "chalk": "^4.1.2",
        "dotenv": "^16.3.1",
        "dotenv-expand": "^10.0.0",
        "express": "^4.18.2",
        "fs-extra": "^11.2.0",
        "lodash": "^4.17.21",
